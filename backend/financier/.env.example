# Copy this file to `.env` (git-ignored). Docker Compose reads it automatically.

# Application database
DB_USERNAME=postgres
DB_PASSWORD=admin
DB_NAME=postgres

# JWT - generate a big random value to put here on production
JWT_SECRET=changeme-dev-secret-changeme-dev-secret-changeme-dev-secret

# API URL used by frontend (built in next.js build)
NEXT_PUBLIC_API_URL=http://localhost:8081/api

# SonarQube database
SONAR_DB_USERNAME=sonar
SONAR_DB_PASSWORD=sonar
